generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model Course {
  courseId        String       @id @default(uuid())
  title           String       @db.VarChar(255)
  description     String?      @db.Text
  thumbnailUrl    String?      @db.Text
  subject         String?      @db.VarChar(100)
  curriculum      String?      @db.VarChar(100)
  level           String?      @db.VarChar(50) 
  instructorId    String       @db.Uuid
  price           Decimal      @default(0) @db.Decimal(12, 2)
  isFree          Boolean      @default(true)
  tags            Json?        @default("[]")
  status          CourseStatus @default(DRAFT)
  version         Int          @default(1)
  parentCourseId  String?      @db.Uuid
  totalDuration   Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  modules         Module[]
  payments        Payment[]
}

model Module {
  moduleId    String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  orderIndex  Int
  status      Status   @default(DRAFT)

  lessons     Lesson[] 
}

model Lesson {
  lessonId     String        @id @default(uuid())
  moduleId     String
  module       Module        @relation(fields: [moduleId], references: [moduleId], onDelete: Cascade)
  title        String        @db.VarChar(255)
  objectives   String?       @db.Text
  duration     Int?
  orderIndex   Int
  status       Status        @default(DRAFT)
  
  contentItems ContentItem[] 
}

model ContentItem {
  contentId   String      @id @default(uuid())
  lessonId    String
  lesson      Lesson      @relation(fields: [lessonId], references: [lessonId], onDelete: Cascade)
  type        ContentType
  title       String?
  description String?     @db.Text
  contentUrl  String?     @db.Text
  metadata    Json?       
  orderIndex  Int
  status      Status      @default(DRAFT)
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Status {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum ContentType {
  VIDEO
  DOCUMENT
  IMAGE
  AUDIO
  OTHER
}

/// Đăng ký (gói + chu kỳ) theo user_id = JWT sub từ auth-service.
model UserSubscription {
  userId        String   @id @map("user_id") @db.VarChar(255)
  planCode      String   @map("plan_code") @db.VarChar(32)
  billingCycle  String   @map("billing_cycle") @db.VarChar(16)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @map("updated_at") @db.Timestamptz(6)

  @@map("user_subscriptions")
}

/// Bảng thanh toán (Spring payment-service + Prisma). Đồng bộ schema với JPA entity.
model Payment {
  id          String   @id @db.Uuid
  userId      String   @map("user_id") @db.VarChar(255)
  /// Thanh toán mua khóa học (tùy chọn). userId vẫn là chuỗi vì bảng User nằm ở auth-service, không có FK DB ở schema content.
  courseId    String?  @map("course_id") @db.Uuid
  course      Course?  @relation(fields: [courseId], references: [courseId], onDelete: SetNull)
  amount      Decimal  @db.Decimal(19, 2)
  currency    String   @db.VarChar(3)
  description String?  @db.VarChar(500)
  planCode    String?  @map("plan_code") @db.VarChar(32)
  billingCycle String? @map("billing_cycle") @db.VarChar(16)
  /// PENDING | PROCESSING | COMPLETED | FAILED | CANCELLED (string để khớp JPA EnumType.STRING)
  status      String   @db.VarChar(32)
  provider    String?  @db.VarChar(32)
  providerRef String?  @map("provider_ref") @db.VarChar(255)
  createdAt   DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @map("updated_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_payments_user_id")
  @@index([courseId], map: "idx_payments_course_id")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}