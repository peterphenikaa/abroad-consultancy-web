# Sao chép thành .env hoặc đặt biến trong .env repo root (Docker).

# PostgreSQL — schema crawler (đồng bộ raw_university_data, raw_visa_data)
CRAWLER_DATABASE_URL=postgresql://user:pass@host:5432/postgres?schema=crawler

# OpenSearch / Bonsai (tương thích Elasticsearch API)
ELASTICSEARCH_NODE=https://user:pass@your-cluster.bonsaisearch.net

# SEARCH_INDEX=study_abroad_data
# SEARCH_PORT=3007
