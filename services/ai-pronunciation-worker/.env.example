# Sao chép thành .env (KHÔNG commit). Worker đọc .env trong thư mục ai-pronunciation-worker.

# --- Stage 1: Whisper (faster-whisper) ---
# Dev: small | medium. Prod paper: large-v3 (cần GPU + RAM)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Stage 2: MFA (phase 2) ---
# MFA_ENABLED=false
# MFA_ACOUSTIC_MODEL=
# MFA_DICTIONARY=

# --- Stage 4: Gemini feedback + ASS rubric (BẮT BUỘC cho pipeline_v1 / độ chính xác cao) ---
# Cách 1: thêm vào file này
# GOOGLE_AI_API_KEY=your-key-here
# Cách 2: đặt GOOGLE_AI_API_KEY trong .env ở repo root (docker-compose / monorepo)
GEMINI_MODEL=gemini-2.5-flash
# ASS_GEMINI_USE_AUDIO=true
# APS_DEBUG_SCORING=true
# APS_RAG_SERVICE_URL=http://localhost:3100

# --- Audio ---
# AUDIO_MIN_DURATION_S=5
# AUDIO_MAX_DURATION_S=120
# AUDIO_MAX_BYTES=25000000

# --- Scoring ---
# VI_PHONEME_WEIGHTS_PATH=data/vi_phoneme_weights.json
# APS_CORS_ORIGINS=http://localhost:80,http://127.0.0.1:80
# APS_DEBUG_SCORING=false
