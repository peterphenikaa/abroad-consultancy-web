generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Role base on RBAC
enum Role {
  STUDENT
  TEACHER
  ORG_ADMIN
  CONTENT_CREATOR
  SUPER_ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  LOCKED
  BANNED
}

model User {
  id             String  @id @default(uuid()) @db.Uuid
  email          String  @unique @db.VarChar(255)
  phoneHash      String? @map("phone_hash") @db.VarChar(255)
  passwordHash   String  @map("password_hash") @db.VarChar(255)
  fullName       String? @map("full_name") @db.VarChar(255)
  role           Role    @default(STUDENT)
  status         Status  @default(ACTIVE)
  subscriptionId String? @map("subscription_id") @db.VarChar(100)
  orgId          String? @map("org_id") @db.VarChar(100)

  // Verification feature
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerified   Boolean   @default(false) @map("phone_verified")

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Phục vụ tính năng Soft Delete

  // Relationships
  sessions    UserSession[]
  userProfile UserProfile?

  @@index([emailVerified])
  @@index([email]) // Tối ưu hóa khi tìm kiếm user lúc đăng nhập
  @@map("users")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceInfo       String?   @map("device_info") @db.Text
  ip               String?   @db.VarChar(45)
  refreshTokenHash String?   @map("refresh_token_hash") @db.VarChar(255)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamp(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamp(6)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // Tối ưu hóa cho job dọn dẹp session hết hạn
  @@index([refreshTokenHash]) // Tối ưu hóa cho lookup refresh token và revocation check
  @@map("user_sessions")
}

model UserProfile {
  id String @id @default(cuid()) @db.VarChar(25)

  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio              String? @db.Text
  avatarUrl        String? @map("avatar_url") @db.VarChar(500)
  educationalLevel String? @map("educational_level") @db.VarChar(100)
  learningGoals    String? @map("learning_goals") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("user_profiles")
}
