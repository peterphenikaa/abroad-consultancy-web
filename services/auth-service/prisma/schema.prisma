generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Role base on RBAC
enum Role {
  STUDENT
  TEACHER
  ORG_ADMIN
  CONTENT_CREATOR
  SUPER_ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  LOCKED
  BANNED
}

model User {
  id              String  @id @default(uuid()) @db.Uuid
  email           String  @unique @db.VarChar(255)
  phone_hash      String? @db.VarChar(255)
  password_hash   String  @db.VarChar(255)
  full_name       String? @db.VarChar(255)
  role            Role    @default(STUDENT)
  status          Status  @default(ACTIVE)
  subscription_id String? @db.VarChar(100)
  org_id          String? @db.VarChar(100)

  // Verification feature
  email_verified    Boolean   @default(false)
  email_verified_at DateTime?
  phone_verified    Boolean   @default(false)

  // Timestamps
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime? // Phục vụ tính năng Soft Delete

  // Relationships
  sessions      UserSession[]
  userProfileId String?       @db.Uuid
  userProfile   UserProfile?

  @@index([email_verified])
  @@index([email]) // Tối ưu hóa khi tìm kiếm user lúc đăng nhập
  @@map("users")
}

model UserSession {
  id                 String    @id @default(uuid()) @db.Uuid
  user_id            String    @db.Uuid
  device_info        String?   @db.Text
  ip                 String?   @db.VarChar(45)
  refresh_token_hash String?   @db.VarChar(255)
  revoked_at         DateTime? @db.Timestamp(6)
  last_used_at       DateTime? @db.Timestamp(6)

  // Timestamps
  created_at DateTime @default(now())
  expires_at DateTime

  // Relationships
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at]) // Tối ưu hóa cho job dọn dẹp session hết hạn
  @@index([refresh_token_hash]) // Tối ưu hóa cho lookup refresh token và revocation check
  @@map("user_sessions")
}

model UserProfile {
  id String @id @default(cuid()) @db.VarChar(25)

  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio               String? @db.Text
  avatar_url        String? @db.VarChar(500)
  educational_level String? @db.VarChar(100)
  learning_goals    String  @db.Text

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([created_at])
  @@map("user_profiles")
}
