# Sao chép thành file .env (KHÔNG commit .env). Worker chỉ đọc .env — đây là mẫu.

# --- Gemini (bắt buộc để chấm điểm LLM) ---
# GOOGLE_AI_API_KEY=

# Chấm bài = generateContent. Chỉ ID ngắn — KHÔNG được có tiền tố models/ (gây 400 unexpected model name format).
# ĐÚNG:
GEMINI_MODEL=gemini-2.5-flash
# Không ghi chú dính ngay sau giá trị trên cùng dòng (vd. ...flash# lời nhắn) — dễ lỗi tên model; ghi chú ở dòng riêng.
# SAI: GEMINI_MODEL=models/gemini-2.5-flash  (models/ chỉ dùng cho GEMINI_EMBEDDING_MODEL bên dưới)
#
# 404 "model not found" = ID sai hoặc model đã gỡ — không phải key sai (key sai thường 401/403).
# Bảng model: https://ai.google.dev/gemini-api/docs/models
#   - Rẻ / nhanh: gemini-2.5-flash-lite
#   - Suy luận sâu: gemini-2.5-pro
#   - Preview 3.x: lấy đúng ID trong AI Studio / docs (ID đổi theo thời gian).

# --- RAG (tuỳ chọn) ---
# AES_RAG_SERVICE_URL=http://localhost:3100
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=cam-edu-descriptors
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# PINECONE_NAMESPACE=

# Embedding Pinecone (khác endpoint với chấm bài; thường có tiền tố models/…)
# GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# Đổi sang embedding thế hệ mới (ví dụ gemini-embedding-2) phải khớp dimension index Pinecone — xem docs.
# GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=768

# --- CORS & debug ---
# AES_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# AES_DEBUG_SCORING=false
