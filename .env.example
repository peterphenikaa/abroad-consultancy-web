# --- payment-service (Spring Boot / Docker profile) ---
# JDBC tới Postgres (Supabase: thường dùng port 5432 trực tiếp cho migration; thêm sslmode=require nếu cần)
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_HOST:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# RS256 cho auth + gateway (dev): chạy `node scripts/generate-dev-jwt-keys.js`, thêm thư mục dev-keys
# JWT_PUBLIC_KEY=@dev-keys/jwt-public.pem
# JWT_PRIVATE_KEY=@dev-keys/jwt-private.pem
# SMTP (Docker: maildev, host maildev:1025 trong compose đã override)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=dev
# SMTP_PASS=dev
